# ===========================================
# 数字政府统一运维管理平台 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入实际值

# ===========================================
# 数据库配置（必需）
# ===========================================
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ops_platform

# 数据库用户名（Docker Compose 使用）
POSTGRES_USER=postgres

# 数据库密码（Docker Compose 使用）
POSTGRES_PASSWORD=postgres

# 数据库名称（Docker Compose 使用）
POSTGRES_DB=ops_platform

# ===========================================
# AI 智能问答配置（可选）
# ===========================================
# Coze API 密钥
COZE_API_KEY=your-coze-api-key

# Coze Bot ID
COZE_BOT_ID=your-bot-id

# ===========================================
# Zabbix 监控集成配置（可选）
# ===========================================
# Zabbix API 地址
NEXT_PUBLIC_ZABBIX_URL=http://your-zabbix-server/zabbix/api_jsonrpc.php

# Zabbix 用户名
ZABBIX_USER=Admin

# Zabbix 密码
ZABBIX_PASSWORD=your-zabbix-password

# ===========================================
# 其他配置
# ===========================================
# Node.js 环境
NODE_ENV=production

# 服务端口（默认 5000）
PORT=5000
