# ===========================================
# 数字政府统一运维管理平台 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入实际值

# ===========================================
# 数据库配置（必需）
# ===========================================
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ops_platform

# 数据库用户名（Docker Compose 使用）
POSTGRES_USER=postgres

# 数据库密码（Docker Compose 使用）
POSTGRES_PASSWORD=postgres

# 数据库名称（Docker Compose 使用）
POSTGRES_DB=ops_platform

# ===========================================
# AI 智能问答配置（可选）
# ===========================================
# Coze API 密钥
COZE_API_KEY=your-coze-api-key

# Coze Bot ID
COZE_BOT_ID=your-bot-id

# ===========================================
# Zabbix 监控集成配置（可选）
# ===========================================
# Zabbix 前端地址（浏览器访问，使用真实 IP 或域名）
# 示例：http://192.168.1.100/zabbix
# 注意：如果 Zabbix 部署在子目录，URL 应包含子目录路径
# 不要包含 /api_jsonrpc.php
NEXT_PUBLIC_ZABBIX_URL=http://your-zabbix-server/zabbix

# Zabbix 后端 API 地址（可选，Docker 容器内访问使用）
# 如果 Zabbix 在同一台服务器上，使用 host.docker.internal
# 如果 Zabbix 在另一台服务器，使用实际 IP 或域名
ZABBIX_API_URL=http://host.docker.internal/zabbix

# Zabbix 用户名
ZABBIX_USER=Admin

# Zabbix 密码
ZABBIX_PASSWORD=your-zabbix-password

# ===========================================
# 其他配置
# ===========================================
# Node.js 环境
NODE_ENV=production

# 服务端口（默认 5000）
PORT=5000
